# Para probar la app móvil con dispositivo físico:
# Opción 1 (recomendada): Cloudflare Tunnel
#   brew install cloudflared
#   cloudflared tunnel --url http://localhost:3001
#   Copia la URL generada aquí:
EXPO_PUBLIC_BACKEND_URL=https://TU-URL.trycloudflare.com

# Opción 2: IP local (solo funciona si el celular está en el mismo WiFi sin firewall)
# EXPO_PUBLIC_BACKEND_URL=http://192.168.X.X:3001
