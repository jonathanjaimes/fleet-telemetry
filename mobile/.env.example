# ── EXPO_PUBLIC_BACKEND_URL ──────────────────────────────────────────────────
# URL del backend (API Node.js, puerto 3001).
# Esta variable la usa la app para enviar GPS, autenticarse y conectar el socket.
# Cambia cada vez que reinicias el túnel.
#
# Opción A — ngrok (recomendada, requiere cuenta gratuita en ngrok.com):
#   1. ngrok config add-authtoken TU_TOKEN   (solo la primera vez)
#   2. ngrok http 3001                        (en una terminal aparte)
#   3. Copia la URL https://xxxx.ngrok-free.app y pégala aquí:
EXPO_PUBLIC_BACKEND_URL=https://xxxx.ngrok-free.app
#
# Opción B — Cloudflare Quick Tunnel (sin cuenta, pero menos estable):
#   brew install cloudflared
#   cloudflared tunnel --url http://localhost:3001
# EXPO_PUBLIC_BACKEND_URL=https://xxxx.trycloudflare.com
#
# Opción C — misma WiFi sin túnel:
# EXPO_PUBLIC_BACKEND_URL=http://192.168.X.X:3001
#
# ── Bundler Metro (puerto 8081) ──────────────────────────────────────────────
# Metro NO necesita configuración en este .env.
# Expo lo expone automáticamente con: npx expo start --tunnel --clear
# (usa el mismo token de ngrok que configuraste arriba)
