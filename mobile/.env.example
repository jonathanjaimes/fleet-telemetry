# ── Backend (API Node, puerto 3001) ─────────────────────────────────────────
# Esta variable NO es el bundler de Expo. Solo define dónde está tu API.
#
# Con dispositivo físico fuera de tu LAN: Cloudflare Quick Tunnel al backend:
#   brew install cloudflared
#   cloudflared tunnel --url http://localhost:3001
# Pega aquí la URL que imprime cloudflared (cambia si reinicias el túnel):
EXPO_PUBLIC_BACKEND_URL=https://TU-URL.trycloudflare.com
#
# Misma WiFi que el PC (sin túnel al backend):
# EXPO_PUBLIC_BACKEND_URL=http://192.168.X.X:3001
#
# ── Bundler Metro (puerto 8081) ─────────────────────────────────────────────
# Si `npx expo start --tunnel` falla, en otra terminal: ngrok http 8081
# El .env de arriba sigue igual: el celular usa Cloudflare para la API y ngrok/LAN para Metro.
